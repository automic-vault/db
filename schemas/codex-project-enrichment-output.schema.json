            "type": "string"
          },
          "category_path": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "category_sources": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "config-file-location": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "linux": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "macos": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "unix": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "windows": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "type": "object"
              }
            ]
          },
          "credentials-file-location": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "linux": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "macos": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "unix": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "windows": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "type": "object"
              }
            ]
          },
          "display-name": {
            "minLength": 1,
            "type": "string"
          },
          "display-name-confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "type": "string"
          },
          "display_name_sources": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "docs": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "docs-confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "type": "string"
          },
          "docs_sources": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "id": {
            "type": "string"
          },
          "repo": {
            "type": [
              "string",
              "null"
            ]
          },
          "repo-confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "type": "string"
          },
          "repo_sources": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "tags-confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "type": "string"
          },
          "tags_sources": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          }
        },
        "required": [
          "id",
          "repo",
          "repo-confidence",
          "display-name",
          "display-name-confidence",
          "category_path",
          "category-confidence",
          "docs",
          "docs-confidence",
          "config-file-location",
          "credentials-file-location",
          "tags",
          "tags-confidence",
          "repo_sources",
          "docs_sources",
          "category_sources",
          "tags_sources",
          "display_name_sources"
