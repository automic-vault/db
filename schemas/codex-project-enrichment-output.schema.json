              "high",
              "medium",
              "low"
            ],
            "type": "string"
          },
          "category_path": {
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "category_sources": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "display-name": {
            "type": "string"
          },
          "display-name-confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "type": "string"
          },
          "display_name_sources": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "docs": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "docs-confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "type": "string"
          },
          "docs_sources": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "id": {
            "type": "string"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "tags-confidence": {
            "enum": [
              "high",
              "medium",
              "low"
            ],
            "type": "string"
          },
          "tags_sources": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "id",
          "display-name",
          "display-name-confidence",
          "category_path",
          "category-confidence",
          "docs",
          "docs-confidence",
          "tags",
          "tags-confidence",
          "docs_sources",
          "category_sources",
          "tags_sources",
          "display_name_sources"
