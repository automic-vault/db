{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automicvault.com/schemas/package-approval-manifest.v0.schema.json",
  "title": "Package Approval Manifest v0",
  "type": "object",
  "required": ["schemaVersion", "package", "coverage", "entrypoints", "rules"],
  "properties": {
    "schemaVersion": {
      "const": "package-approval-manifest.v0"
    },
    "package": {
      "type": "object",
      "required": ["namespace", "name", "displayName", "upstream"],
      "properties": {
        "namespace": { "type": "string" },
        "name": { "type": "string" },
        "displayName": { "type": "string" },
        "description": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "upstream": { "type": "object" }
      },
      "additionalProperties": true
    },
    "analytics": {
      "type": "object",
      "required": ["source", "period", "rank", "installOnRequest"],
      "additionalProperties": true
    },
    "coverage": {
      "type": "object",
      "required": ["status", "reviewedAt"],
      "properties": {
        "status": {
          "enum": ["stub", "partial", "broad", "exhaustive"]
        },
        "reviewedAt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "kind"],
        "additionalProperties": true
      }
    },
    "unknownCommandPolicy": {
      "type": "object",
      "additionalProperties": true
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "entrypoint", "match", "consequences", "severity", "confidence", "gate", "explain"],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

